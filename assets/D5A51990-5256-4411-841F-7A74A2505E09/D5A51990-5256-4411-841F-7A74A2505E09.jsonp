7664948,"x":828.00761733174329,"width":16.459999999999923,"height":13}},{"text":"Different subtrees","targetRectangle":{"y":1374.4530030786991,"x":438.652223944664,"width":79.940000000000055,"height":13}},{"text":"Subparts are easier to recognize when they belong to the same subtree","targetRectangle":{"y":1164.1501466035843,"x":714.66571044921875,"width":355.61999999999989,"height":52}},{"text":"Modified incongruent","targetRectangle":{"y":1020.0550538599491,"x":572.05625128746033,"width":94.700000000000045,"height":13}},{"text":"3","targetRectangle":{"y":911.84134981036186,"x":249.59864115715027,"width":5.5999999999999943,"height":13}},{"text":"trace","targetRectangle":{"y":544.7925773859024,"x":876.4164814758301,"width":24.079999999999927,"height":13}},{"text":"segment","targetRectangle":{"y":557.7925773859024,"x":869.43648147583008,"width":38.039999999999964,"height":13}},{"text":"+","targetRectangle":{"y":1394.4655758142471,"x":172.82389831542969,"width":6.3600000000000136,"height":14}},{"text":"Sample: Encode","targetRectangle":{"y":1230.1553955972195,"x":211.53923296928406,"width":86.100000000000023,"height":16}},{"text":"Target: Same shape?","targetRectangle":{"y":867.26812753081322,"x":394.73844361305237,"width":110.51999999999998,"height":16}},{"text":"Rotated different","targetRectangle":{"y":1374.1607667505741,"x":615.27073264122009,"width":75.460000000000036,"height":13}},{"text":"repeat","targetRectangle":{"y":741.66555750370026,"x":900.92628685951229,"width":29.889999999999986,"height":13}},{"text":"3 times","targetRectangle":{"y":754.66555750370026,"x":899.63128685951233,"width":32.480000000000018,"height":13}},{"text":"Experiment 2: Subtree Facilitation","targetRectangle":{"y":1165.9140625,"x":25.25,"width":469.17000000000007,"height":39}},{"text":"Experiment 3: Movement Depth","targetRectangle":{"y":1545.1591796875,"x":25.25,"width":434.40000000000009,"height":39}},{"text":"Structure","targetRectangle":{"y":1357.4323733448982,"x":144.43370878696442,"width":58.744,"height":18}},{"text":"1","targetRectangle":{"y":911.84134981036186,"x":225.84444379806519,"width":5.5999999999999943,"height":13}},{"text":"Matches","targetRectangle":{"y":1724.1312258839607,"x":389.04505324363708,"width":53.269999999999982,"height":18}},{"text":"Background","targetRectangle":{"y":429.89321899414062,"x":28.606538772583008,"width":165.12,"height":45}},{"text":"We build on the recent proposal that geometric shapes are represented in a language of thought (LOT) consisting of a handful of primitives that can be combined to recreate the encoded shape (Sablé-Meyer et al. 2022)","targetRectangle":{"y":474.89321899414062,"x":28.606538772583008,"width":654.16999999999996,"height":90.5}},{"text":"Adults’ reaction times and error rates in encoding shapes were predicted by the minimum description length (MDL) of the hypothesized LOT","targetRectangle":{"y":565.39321899414062,"x":28.606538772583008,"width":657.44000000000005,"height":64.5}},{"text":"This fuses two aspects of geometric shape representations that are partly independent, format (LOT) and selection (MDL), and uses MDL data to argue for LOT—highly indirect evidence","targetRectangle":{"y":629.89321899414062,"x":28.606538772583008,"width":658.04999999999995,"height":90.5}},{"text":"Current study provides more direct evidence for tree structure in geometric shape representations in 3 online experiments with adults","targetRectangle":{"y":720.39321899414062,"x":28.606538772583008,"width":611.35999999999979,"height":52}},{"text":"50 subjects | 128 trials","targetRectangle":{"y":1205.4366458058357,"x":25.25,"width":138.09600000000003,"height":18}},{"text":"Modified congruent","targetRectangle":{"y":1020.0550538599491,"x":472.52647352218628,"width":86.970000000000027,"height":13}},{"text":"Matches","targetRectangle":{"y":1003.567322075367,"x":352.91987013816833,"width":53.269999999999982,"height":18}},{"text":"+","targetRectangle":{"y":1042.428833335638,"x":201.32562255859375,"width":7.419